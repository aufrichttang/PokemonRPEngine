APP_ENV=dev
APP_NAME=pokemon-rp-engine
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
JSON_LOGS=true
LOG_TO_FILE=true
LOG_FILE_PATH=logs/rp-engine.log
REQUEST_LOG_ENABLED=true
SLOW_REQUEST_MS=800
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/pokemon_rp
REDIS_URL=redis://redis:6379/0

JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

LLM_PROVIDER=xfyun_http
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
XF_AUTH_MODE=bearer
XF_APPID=
XF_API_KEY=
XF_API_SECRET=
XF_MODEL_ID=xopglm5
XF_BASE_URL_HTTP=https://maas-api.cn-huabei-1.xf-yun.com/v2
XF_BASE_URL_WS=wss://maas-api.cn-huabei-1.xf-yun.com/v1.1/chat

EMBEDDING_PROVIDER=fake
EMBEDDING_DIM=768

SHORT_WINDOW_TURNS=12
VECTOR_TOP_K=12
TIMELINE_TOP_N=8
MAX_CANON_FACTS=15
MAX_RECALLS=15
MAX_OPEN_THREADS=10
MAX_PROMPT_TOKENS_BUDGET=6000

RATE_LIMIT_QPS=5
RATE_LIMIT_BURST=5
AUDIT_CONTENT_ENABLED=true
BOOTSTRAP_DEFAULT_ADMIN=true
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin
RP_OPEN_BROWSER=0
RP_DESKTOP_FRONTEND_MODE=dev
