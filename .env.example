APP_ENV=dev
APP_NAME=pokemon-rp-engine
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
JSON_LOGS=true
LOG_TO_FILE=true
LOG_FILE_PATH=logs/rp-engine.log
REQUEST_LOG_ENABLED=true
SLOW_REQUEST_MS=800
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/pokemon_rp
REDIS_URL=redis://redis:6379/0

JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

LLM_PROVIDER=xfyun_http
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_CONNECT_TIMEOUT_SECONDS=5
LLM_READ_TIMEOUT_SECONDS=60
LLM_PLANNER_TIMEOUT_SECONDS=12
LLM_PLANNER_MAX_TOKENS=180
LLM_NARRATIVE_MAX_TOKENS=900
LLM_NARRATIVE_MAX_TOKENS_FAST=700
LLM_NARRATIVE_MAX_TOKENS_BALANCED=900
LLM_NARRATIVE_MAX_TOKENS_EPIC=1200
LLM_NARRATIVE_CLIMAX_MAX_TOKENS=1400
CANON_REPAIR_MODE=smart
CANON_REPAIR_ISSUE_LIMIT=2
STORY_ENHANCEMENT_ENABLED=true
STORY_ENHANCEMENT_TIMEOUT_SECONDS=8
XF_AUTH_MODE=bearer
XF_APPID=
XF_API_KEY=
XF_API_SECRET=
XF_MODEL_ID=xopglm5
XF_BASE_URL_HTTP=https://maas-api.cn-huabei-1.xf-yun.com/v2
XF_BASE_URL_WS=wss://maas-api.cn-huabei-1.xf-yun.com/v1.1/chat

EMBEDDING_PROVIDER=fake
EMBEDDING_DIM=768

SHORT_WINDOW_TURNS=4
VECTOR_TOP_K=12
TIMELINE_TOP_N=8
MAX_CANON_FACTS=6
MAX_RECALLS=6
MAX_OPEN_THREADS=4
MAX_PROMPT_TOKENS_BUDGET=2200

RATE_LIMIT_QPS=5
RATE_LIMIT_BURST=5
AUDIT_CONTENT_ENABLED=true
BOOTSTRAP_DEFAULT_ADMIN=true
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin
AUTH_BYPASS_LOCAL=true
AUTH_BYPASS_USERNAME=local_player
AUTH_BYPASS_ROLE=admin
DESKTOP_AUTO_LOGIN=true
DESKTOP_AUTO_USERNAME=admin
DESKTOP_AUTO_PASSWORD=admin
RP_OPEN_BROWSER=0
RP_DESKTOP_FRONTEND_MODE=dev
NEXT_PUBLIC_RP_DEV_DEBUG_UI=false
